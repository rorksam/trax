# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
dist-ssr/
build/
*.local

# Vite
.vite/

# Environment files — never commit secrets
.env
.env.local
.env.*.local
!.env.example

# Supabase local stack
# config.toml IS committed; everything else under supabase/ is local state.
supabase/.branches/
supabase/.temp/
supabase/.env
supabase/seed.sql.bak

# Editor / IDE
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Test / coverage
coverage/
.nyc_output/

# PWA / service worker generated assets (will live under dist/ but keep explicit)
sw.js.map
workbox-*.js
workbox-*.js.map

# VAPID keys — never commit. Live in env vars + Supabase secrets.
vapid-keys.json
