# Supabase connection — copy this file to .env.local and fill in real values.
# Run `supabase status` to see the values for your local stack.

# Public Supabase URL. Local default: http://127.0.0.1:54321
VITE_SUPABASE_URL=

# Publishable (anon) key. Safe to ship in client bundle — it's gated by RLS.
# Local stack default starts with sb_publishable_*
VITE_SUPABASE_PUBLISHABLE_KEY=
